generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String     @id @default(uuid())
  fullName     String
  email        String     @unique
  mobile       String
  extension    String
  passwordHash String
  role         String     @default("EMPLOYEE")
  status       String     @default("ACTIVE")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  loans        Loan[]

  @@map("users")
}

model Loan {
  id          String   @id @default(uuid())
  refNumber   String   @unique
  userId      String?
  employee    String
  activity    String
  location    String?
  amount      Float
  budgetApproved Boolean?
  startDate   DateTime
  endDate     DateTime
  files       Json?
  reviewStatus String @default("PENDING")
  reviewNote   String?
  isSettled   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  printedAt   DateTime?
  
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  settlement  Settlement?
  items       LoanItem[]

  @@map("loans")
}

model LoanItem {
  id       String @id @default(uuid())
  category String
  amount   Float
  loanId   String
  loan     Loan   @relation(fields: [loanId], references: [id], onDelete: Cascade)
  
  @@map("loan_items")
}

model Settlement {
  id             String   @id @default(uuid())
  supported      Float    @default(0)
  unsupported    Float    @default(0)
  total          Float    @default(0)
  savings        Float    @default(0)
  overage        Float    @default(0)
  invoices       Json?
  loanId         String   @unique
  loan           Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())

  @@map("settlements")
}
